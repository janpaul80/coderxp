# ─── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://codedxp:codedxp_secret@localhost:5432/codedxp_db"

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Auth ─────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-in-production

# ─── AI / Model Routing ───────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
BLACKBOX_API_KEY=

# ─── Stripe Billing ───────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (create in Stripe dashboard or via CLI)
# Basic plan: $3 first month → $9/month
STRIPE_PRICE_BASIC=
STRIPE_PRICE_BASIC_PROMO=

# Pro plan: $19/month
STRIPE_PRICE_PRO=

# Teams plan: $49/month
STRIPE_PRICE_TEAMS=

# ─── Storage ──────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# ─── Preview Runtime ──────────────────────────────────────────
PREVIEW_BASE_PORT=3100
PREVIEW_MAX_CONTAINERS=10
DOCKER_SOCKET=/var/run/docker.sock
